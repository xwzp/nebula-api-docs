---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FeatureCard from '../components/FeatureCard.astro';
---

<BaseLayout title="Nebula API - Unified AI Infrastructure">
  <div class="min-h-screen bg-white dark:bg-dark-bg transition-colors">
    <Header variant="landing" />

    {/* Hero */}
    <section class="relative overflow-hidden">
      {/* Background glow */}
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gradient-to-r from-accent-magenta/5 dark:from-accent-magenta/10 via-accent-purple/5 dark:via-accent-purple/10 to-accent-blue/5 dark:to-accent-blue/10 blur-[100px] rounded-full"></div>
      </div>

      <div class="relative max-w-[1400px] mx-auto px-6 pt-24 pb-20 text-center">
        <h1 class="font-display font-extrabold text-5xl md:text-7xl text-light-text dark:text-white mb-6 leading-tight">
          Nebula <span class="gradient-text">API</span>
        </h1>
        <p class="text-lg md:text-xl text-light-text-muted dark:text-dark-text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
          A unified, high-performance API infrastructure providing seamless
          access to leading AI models with unparalleled speed and reliability.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/docs/getting-started" class="gradient-btn px-6 py-3 rounded-full text-white font-semibold text-sm hover:opacity-90 transition-opacity">
            Get Started
          </a>
          <a href="/docs/model-apis" class="px-6 py-3 rounded-full font-semibold text-sm bg-light-text dark:bg-white/10 text-white dark:text-white border border-light-text dark:border-white/20 hover:bg-light-text/90 dark:hover:bg-white/15 transition-colors">
            Explore APIs
          </a>
          <a href="#" class="px-6 py-3 rounded-full font-semibold text-sm border text-light-text-muted dark:text-dark-text-muted border-light-border dark:border-dark-border hover:border-accent-purple/50 hover:text-light-text dark:hover:text-white transition-colors flex items-center gap-1.5">
            Official Website
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    {/* Features */}
    <section class="max-w-[1400px] mx-auto px-6 pb-24">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        <FeatureCard
          title="Instant Setup"
          description="Get your API keys in seconds and start building immediately with our zero-friction onboarding."
          icon="⚡"
          glowColor="pink"
        />
        <FeatureCard
          title="Affordable Pricing"
          description="Pay only for what you use with industry-leading rates and transparent billing cycles."
          icon="💎"
          glowColor="purple"
        />
        <FeatureCard
          title="Enterprise Security"
          description="Enterprise-grade encryption and privacy protocols ensuring your data stays protected."
          icon="🛡️"
          glowColor="blue"
        />
        <FeatureCard
          title="Unified SDK"
          description="One standardized API format for all major models, reducing integration complexity."
          icon="🧩"
          glowColor="pink"
        />
      </div>
    </section>

    <Footer variant="landing" />
  </div>
</BaseLayout>
