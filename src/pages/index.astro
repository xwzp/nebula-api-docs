---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FeatureCard from '../components/FeatureCard.astro';
---

<BaseLayout title="Nebula API - Unified AI Infrastructure">
  <div class="min-h-screen bg-white dark:bg-slate-900 transition-colors pt-16">
    <Header variant="landing" />

    {/* Hero */}
    <section class="relative">
      <div class="max-w-[896px] mx-auto px-6 pt-32 pb-20 flex flex-col items-center text-center">
        <h1 class="font-display font-extrabold text-[72px] text-slate-900 dark:text-white leading-none tracking-[-1.8px] mb-6">
          Nebula <span class="gradient-text">API</span>
        </h1>
        <p class="text-xl text-slate-600 dark:text-slate-400 max-w-[672px] leading-relaxed mb-10">
          统一、高性能的 API 基础设施，为您提供对领先 AI 模型的无缝访问，具有无与伦比的速度和可靠性。
        </p>

        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/docs/getting-started"
            class="get-started-btn gradient-btn px-8 py-4 rounded-full text-white font-bold text-lg hover:opacity-90 transition-opacity"
          >
            开始使用
          </a>
          <a
            href="#"
            class="official-site-btn px-8 py-4 rounded-full font-bold text-lg bg-gray-100/50 dark:bg-slate-800/50 text-slate-800 dark:text-slate-200 border border-pink-200/30 dark:border-blue-500/20 hover:bg-gray-100 dark:hover:bg-slate-800 transition-colors flex items-center gap-2"
          >
            官方网站
            <svg class="w-3 h-3" viewBox="0 0 12.5 12.5" fill="currentColor">
              <path d="M1.16667 12.5L0 11.3333L9.66667 1.66667H4.16667V0H12.5V8.33333H10.8333V2.83333L1.16667 12.5Z"/>
            </svg>
          </a>
        </div>

        <style>
          .get-started-btn {
            box-shadow: 0 20px 25px -5px #e9d5ff, 0 8px 10px -6px #e9d5ff;
          }
          :global(.dark) .get-started-btn {
            box-shadow: 0 20px 25px -5px rgba(139, 92, 246, 0.3), 0 8px 10px -6px rgba(139, 92, 246, 0.2);
          }
          .official-site-btn {
            box-shadow: 0 20px 25px -5px #e2e8f0, 0 8px 10px -6px #e2e8f0;
          }
          :global(.dark) .official-site-btn {
            box-shadow: 0 20px 25px -5px rgba(139, 92, 246, 0.3), 0 8px 10px -6px rgba(139, 92, 246, 0.2);
          }
        </style>
      </div>
    </section>

    {/* Features */}
    <section id="features" class="px-8 py-24">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-[1280px] mx-auto">
        <FeatureCard
