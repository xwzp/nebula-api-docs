---
import Logo from './Logo.astro';
import { headerNav, sidebarSections } from '../config/navigation';

interface Props {
  variant?: 'landing' | 'docs';
}

const { variant = 'docs' } = Astro.props;
---

{variant === 'docs' ? (
  <!-- Docs header: sticky, responsive light/dark -->
  <header class="sticky top-0 z-50 h-16 bg-white dark:bg-slate-900 border-b border-slate-100 dark:border-slate-800 px-8 flex items-center justify-between transition-colors">
    <div class="flex items-center gap-6">
      <Logo />
      <button data-search-trigger class="hidden md:flex items-center gap-3 h-10 px-4 bg-slate-50/50 dark:bg-slate-800/50 hover:bg-slate-100 dark:hover:bg-slate-800 border border-blue-100 dark:border-blue-900/30 rounded-lg transition-all shadow-sm cursor-pointer">
        <svg class="w-4 h-4 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <span class="text-[14px] text-slate-500 dark:text-slate-400 font-medium">搜索文档</span>
        <div class="flex items-center gap-1 px-1.5 py-0.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded text-[11px] text-slate-400 font-mono shadow-sm">
          <span>⌘</span><span>K</span>
        </div>
      </button>
    </div>

    <div class="flex items-center gap-2">
      <nav class="hidden xl:flex items-center gap-1 mr-2">
        {sidebarSections.map((section) => (
          <a
            href={section.items[0].href}
            class="text-[14px] font-medium px-2 py-2 rounded-lg transition-colors text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100"
          >
            {section.title}
          </a>
        ))}
      </nav>

      <div class="w-px h-6 bg-slate-200 dark:bg-slate-700" />

      <button
        id="theme-toggle"
        class="relative flex items-center p-0.5 bg-slate-100 dark:bg-slate-800 rounded-full border border-slate-200 dark:border-slate-700 w-12 h-[26px] transition-colors cursor-pointer ml-2"
        aria-label="Toggle theme"
      >
        <div class="w-[22px] h-[22px] rounded-full bg-white dark:bg-slate-900 shadow-sm flex items-center justify-center transition-all duration-300 translate-x-0 dark:translate-x-[22px]">
          <svg class="w-3 h-3 text-yellow-500 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg class="w-3 h-3 text-blue-400 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </div>
      </button>
    </div>
  </header>

  <script>
    const toggle = document.getElementById('theme-toggle');
    const html = document.documentElement;
    toggle?.addEventListener('click', () => {
      const isDark = !html.classList.contains('dark');
      html.classList.toggle('dark', isDark);
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  </script>
) : (
  <!-- Landing header: fixed, backdrop blur, responsive -->
  <header class="fixed top-0 left-0 right-0 z-50 h-16 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-100 dark:border-slate-800 px-8 flex items-center justify-between transition-colors">
    <div class="flex items-center gap-6">
      <Logo />
      <button data-search-trigger class="hidden md:flex items-center gap-3 h-10 px-4 bg-slate-50/50 dark:bg-slate-800/50 hover:bg-slate-100 dark:hover:bg-slate-800 border border-blue-100 dark:border-blue-900/30 rounded-lg transition-all shadow-sm cursor-pointer">
        <svg class="w-4 h-4 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <span class="text-[14px] text-slate-500 dark:text-slate-400 font-medium">搜索文档</span>
        <div class="flex items-center gap-1 px-1.5 py-0.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded text-[11px] text-slate-400 font-mono shadow-sm">
          <span>⌘</span><span>K</span>
        </div>
      </button>
    </div>

    <div class="flex items-center gap-2">
      <!-- System Status badge -->
      <a href="#" class="hidden md:flex items-center gap-1.5 px-4 py-2 bg-gray-100/50 dark:bg-slate-800/50 rounded-full text-[14px] font-medium text-slate-700 dark:text-slate-300 border border-pink-200/30 dark:border-blue-500/20 transition-colors hover:bg-gray-100 dark:hover:bg-slate-800 mr-2">
        <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
        System Status
      </a>

      <div class="w-px h-6 bg-slate-200 dark:bg-slate-700 mr-2" />

      <button
        id="theme-toggle"
        class="relative flex items-center p-0.5 bg-slate-100 dark:bg-slate-800 rounded-full border border-slate-200 dark:border-slate-700 w-12 h-[26px] transition-colors cursor-pointer"
        aria-label="Toggle theme"
      >
        <div class="w-[22px] h-[22px] rounded-full bg-white dark:bg-slate-900 shadow-sm flex items-center justify-center transition-all duration-300 translate-x-0 dark:translate-x-[22px]">
          <svg class="w-3 h-3 text-yellow-500 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg class="w-3 h-3 text-blue-400 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </div>
      </button>

      <div class="w-px h-6 bg-slate-200 dark:bg-slate-700 ml-2" />
    </div>
  </header>

  <script>
    const toggle = document.getElementById('theme-toggle');
    const html = document.documentElement;
    toggle?.addEventListener('click', () => {
      const isDark = !html.classList.contains('dark');
      html.classList.toggle('dark', isDark);
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  </script>
)}
