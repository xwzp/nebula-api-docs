---

<aside class="sticky top-16 h-[calc(100vh-4rem)] w-64 shrink-0 hidden lg:block overflow-y-auto bg-[#f9fafb] dark:bg-slate-800/40 border-r border-slate-100 dark:border-slate-800 transition-colors">
  <div class="flex flex-col py-4 px-4">
    {sidebarSections.map((section, idx) => (
      <div class="mb-4">
        <div class="flex items-center justify-between py-2 text-slate-900 dark:text-slate-100 font-bold text-[14px] cursor-pointer group">
          <span>{section.title}</span>
          <svg class="w-3.5 h-3.5 text-slate-400 group-hover:text-slate-600 dark:group-hover:text-slate-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
        <div class="space-y-0.5">
          {section.items.map((item) => (
            <a
              href={item.href}
              class:list={[
                "flex items-center gap-3 px-2 py-1.5 rounded-md transition-all text-[13px]",
                isActive(item.href)
                  ? "bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 font-medium"
                  : "text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700/50"
              ]}
            >
              <svg class:list={["w-[18px] h-[18px] shrink-0", isActive(item.href) ? "text-blue-500 dark:text-blue-400" : item.color]} viewBox="0 0 24 24" fill="currentColor">
                <path d={icons[item.icon] || icons.info} />
              </svg>
              <span>{item.label}</span>
            </a>
          ))}
        </div>
        {idx < sidebarSections.length - 1 && (
          <div class="h-px bg-slate-200/30 dark:bg-slate-700/30 mt-4" />
        )}
      </div>
    ))}
  </div>
</aside>

<script is:inline>
  // 标准化路径：移除末尾斜杠，解码 URL
  function normalizePath(path) {
    return decodeURIComponent(path).replace(/\/+$/, '');
  }

  // 客户端处理锚点链接高亮
  function updateHashLinkHighlight() {
    const currentPath = normalizePath(window.location.pathname);
    const currentHash = decodeURIComponent(window.location.hash);
    const hasHash = currentHash.length > 0;

    document.querySelectorAll('aside a').forEach((link) => {
      const rawHref = link.getAttribute('href');
      if (!rawHref || rawHref === '#') return;

      const svg = link.querySelector('svg');
      const normalizedHref = normalizePath(rawHref.split('#')[0]);
      const isHashLink = rawHref.includes('#');
      let shouldHighlight = false;

      if (isHashLink) {
        // 带 hash 的链接：路径和 hash 都要匹配
        const hrefHash = '#' + decodeURIComponent(rawHref.split('#')[1]);
        shouldHighlight = normalizedHref === currentPath && hrefHash === currentHash;
      } else {
        // 普通链接：只有当 URL 没有 hash 时才高亮
        shouldHighlight = normalizedHref === currentPath && !hasHash;
      }

      if (shouldHighlight) {
        link.classList.remove('text-slate-600', 'dark:text-slate-400', 'hover:bg-slate-100', 'dark:hover:bg-slate-700/50');
        link.classList.add('bg-blue-50', 'dark:bg-blue-900/20', 'text-blue-600', 'dark:text-blue-400', 'font-medium');
        if (svg) {
          svg.classList.remove('text-slate-500');
          svg.classList.add('text-blue-500', 'dark:text-blue-400');
        }
      } else {
        link.classList.remove('bg-blue-50', 'dark:bg-blue-900/20', 'text-blue-600', 'dark:text-blue-400', 'font-medium');
        link.classList.add('text-slate-600', 'dark:text-slate-400', 'hover:bg-slate-100', 'dark:hover:bg-slate-700/50');
        if (svg) {
          svg.classList.remove('text-blue-500', 'dark:text-blue-400');
        }
      }
    });
  }

  // 保存和恢复侧边栏滚动位置
  const SIDEBAR_SCROLL_KEY = 'sidebar-scroll-position';

  function saveSidebarScroll() {
    const sidebar = document.querySelector('aside');
    if (sidebar) {
      sessionStorage.setItem(SIDEBAR_SCROLL_KEY, sidebar.scrollTop.toString());
    }
  }

  function restoreSidebarScroll() {
    const sidebar = document.querySelector('aside');
    if (sidebar) {
      const savedPosition = sessionStorage.getItem(SIDEBAR_SCROLL_KEY);
      if (savedPosition) {
        sidebar.scrollTop = parseInt(savedPosition, 10);
      }
    }
  }

  // 页面加载和 hash 变化时更新
  updateHashLinkHighlight();
  restoreSidebarScroll();

  // 点击侧边栏链接时保存滚动位置
  document.querySelectorAll('aside a').forEach((link) => {
    link.addEventListener('click', saveSidebarScroll);
  });

  window.addEventListener('hashchange', updateHashLinkHighlight);
</script>
