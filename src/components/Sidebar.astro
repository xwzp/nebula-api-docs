---
import { sidebarNav } from '../config/navigation';

const currentPath = Astro.url.pathname;

function isActive(href?: string) {
  if (!href) return false;
  return currentPath === href || currentPath === href + '/';
}

function hasActiveChild(items?: { href?: string }[]) {
  if (!items) return false;
  return items.some((item) => isActive(item.href));
}

const icons: Record<string, string> = {
  rocket: 'M13 10V3L4 14h7v7l9-11h-7z',
  code: 'M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z',
  book: 'M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z',
  api: 'M14 12l-2 2-2-2 2-2 2 2zm-2-6l2.12 2.12 2.5-2.5L12 1 7.38 5.62l2.5 2.5L12 6zm-6 6l2.12-2.12-2.5-2.5L1 12l4.62 4.62 2.5-2.5L6 12zm12 0l-2.12 2.12 2.5 2.5L23 12l-4.62-4.62-2.5 2.5L18 12zm-6 6l-2.12-2.12-2.5 2.5L12 23l4.62-4.62-2.5-2.5L12 18z',
  payments: 'M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z',
  groups: 'M12 12.75c1.63 0 3.07.39 4.24.9 1.08.48 1.76 1.56 1.76 2.73V18H6v-1.61c0-1.18.68-2.26 1.76-2.73 1.17-.52 2.61-.91 4.24-.91zM4 13c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm1.13 1.1c-.37-.06-.74-.1-1.13-.1-.99 0-1.93.21-2.78.58C.48 14.9 0 15.62 0 16.43V18h4.5v-1.61c0-.83.23-1.61.63-2.29zM20 13c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm4 3.43c0-.81-.48-1.53-1.22-1.85A6.95 6.95 0 0020 14c-.39 0-.76.04-1.13.1.4.68.63 1.46.63 2.29V18H24v-1.57zM12 6c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3z',
};
---

<aside class="w-64 shrink-0 hidden lg:block">
  <nav class="sticky top-20 h-[calc(100vh-5rem)] overflow-y-auto pb-8 pr-4">
    <ul class="space-y-1">
      {sidebarNav.map((item) => (
        <li>
          {item.items ? (
            <div>
              <div class="flex items-center gap-2 px-3 py-2 text-sm font-semibold text-light-text dark:text-dark-text">
                {item.icon && icons[item.icon] && (
                  <svg class="w-4 h-4 text-light-text-muted dark:text-dark-text-muted" viewBox="0 0 24 24" fill="currentColor">
                    <path d={icons[item.icon]} />
                  </svg>
                )}
                {item.title}
              </div>
              <ul class="ml-4 border-l border-light-border dark:border-dark-border space-y-0.5">
                {item.items.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={[
                        "block pl-4 pr-3 py-1.5 text-sm rounded-r-lg transition-colors -ml-px border-l-2",
                        isActive(child.href)
                          ? "border-accent-purple bg-accent-purple/10 text-accent-purple font-medium"
                          : "border-transparent text-light-text-muted dark:text-dark-text-muted hover:text-light-text dark:hover:text-dark-text hover:bg-gray-50 dark:hover:bg-white/5"
                      ]}
                    >
                      {child.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                "flex items-center gap-2 px-3 py-2 text-sm rounded-lg transition-colors",
                isActive(item.href)
                  ? "bg-accent-purple/10 text-accent-purple font-medium"
                  : "text-light-text-muted dark:text-dark-text-muted hover:text-light-text dark:hover:text-dark-text hover:bg-gray-50 dark:hover:bg-white/5"
              ]}
            >
              {item.icon && icons[item.icon] && (
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d={icons[item.icon]} />
                </svg>
              )}
              {item.title}
            </a>
          )}
        </li>
      ))}
    </ul>
  </nav>
</aside>
