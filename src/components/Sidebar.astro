---
import { sidebarSections } from '../config/navigation';

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '#') return false;

  // 带 hash 的链接在服务端无法判断，交给客户端处理
  if (href.includes('#')) {
    return false;
  }

  // 普通链接
  return currentPath === href || currentPath === href + '/';
}

