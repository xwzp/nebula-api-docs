---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<a href="/" class:list={["flex items-center gap-2 font-display font-bold text-xl tracking-tight", className]}>
  <div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center shadow-sm">
    <svg class="w-[18px] h-[18px] text-white" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8L12 2z"/>
    </svg>
  </div>
  <span class="gradient-text">Nebula API</span>
</a>
