---
interface Props {
  type?: 'info' | 'warning' | 'tip' | 'important';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const styles = {
  info: {
    border: 'border-accent-blue',
    bg: 'bg-accent-blue/5',
    icon: 'text-accent-blue',
    iconPath: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z',
    defaultTitle: 'Note',
  },
  warning: {
    border: 'border-amber-500',
    bg: 'bg-amber-500/5',
    icon: 'text-amber-500',
    iconPath: 'M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z',
    defaultTitle: 'Warning',
  },
  tip: {
    border: 'border-emerald-500',
    bg: 'bg-emerald-500/5',
    icon: 'text-emerald-500',
    iconPath: 'M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7z',
    defaultTitle: 'Tip',
  },
  important: {
    border: 'border-accent-pink',
    bg: 'bg-accent-pink/5',
    icon: 'text-accent-pink',
    iconPath: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z',
    defaultTitle: 'Important Note',
  },
};

const s = styles[type];
---

<div class:list={["rounded-xl border-l-4 p-4 my-6", s.border, s.bg]}>
  <div class="flex items-start gap-3">
    <svg class:list={["w-5 h-5 mt-0.5 shrink-0", s.icon]} viewBox="0 0 24 24" fill="currentColor">
      <path d={s.iconPath} />
    </svg>
    <div>
      <p class:list={["font-semibold text-sm mb-1", s.icon]}>
        {title || s.defaultTitle}
      </p>
      <div class="text-sm text-dark-text-muted [&>p]:mb-0">
        <slot />
      </div>
    </div>
  </div>
</div>
