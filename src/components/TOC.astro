---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <aside class="w-56 shrink-0 hidden xl:block">
    <div class="sticky top-20">
      <h4 class="text-xs font-semibold uppercase tracking-wider text-dark-text-muted mb-3">
        On this page
      </h4>
      <nav>
        <ul class="space-y-1.5 text-sm border-l border-dark-border">
          {filteredHeadings.map((heading) => (
            <li>
              <a
                href={`#${heading.slug}`}
                class:list={[
                  "block -ml-px border-l-2 border-transparent py-0.5 transition-colors text-dark-text-muted hover:text-accent-purple hover:border-accent-purple/50",
                  heading.depth === 2 ? "pl-4" : "pl-7",
                ]}
                data-toc-link
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="mt-8 rounded-xl border border-dark-border p-4">
        <p class="font-display font-semibold text-sm text-dark-text">
          Need help?
        </p>
        <p class="text-xs text-dark-text-muted mt-1">
          Join our developer Discord for real-time support.
        </p>
        <a
          href="/docs/community"
          class="mt-3 block text-center text-sm font-medium px-3 py-1.5 rounded-lg bg-accent-purple/10 text-accent-purple hover:bg-accent-purple/20 transition-colors"
        >
          Join Community
        </a>
      </div>
    </div>
  </aside>
)}

<script>
  const tocLinks = document.querySelectorAll('[data-toc-link]');
  const headings = document.querySelectorAll('.docs-content h2, .docs-content h3');

  if (tocLinks.length > 0 && headings.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => {
              link.classList.remove('!text-accent-purple', '!border-accent-purple');
            });
            const activeLink = document.querySelector(
              `[data-toc-link][href="#${entry.target.id}"]`
            );
            if (activeLink) {
              activeLink.classList.add('!text-accent-purple', '!border-accent-purple');
            }
          }
        });
      },
      { rootMargin: '-80px 0px -80% 0px' }
    );

    headings.forEach((heading) => observer.observe(heading));
  }
</script>
