---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <aside class="sticky top-16 h-[calc(100vh-4rem)] w-72 shrink-0 hidden xl:block overflow-y-auto border-l border-slate-100 dark:border-slate-800 transition-colors">
    <div class="px-8 py-10">
      <h3 class="text-slate-900 dark:text-slate-200 text-[13px] font-semibold tracking-[1.3px] uppercase mb-6">
        On this page
      </h3>
      <nav>
        <ul class="space-y-3">
          {filteredHeadings.map((heading) => (
            <li>
              <a
                href={`#${heading.slug}`}
                class:list={[
                  "block text-[14px] transition-colors text-slate-500 dark:text-slate-400 hover:text-pink-600 dark:hover:text-pink-400",
                  heading.depth === 3 && "pl-4",
                ]}
                data-toc-link
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Help card -->
      <div class="mt-8 bg-gradient-to-br from-purple-500/10 to-blue-500/10 rounded-2xl p-6 border border-slate-100 dark:border-slate-800 relative overflow-hidden">
        <div class="relative z-10 space-y-3">
          <p class="text-purple-600 dark:text-purple-400 text-[12px] font-semibold">Need help?</p>
          <p class="text-slate-500 dark:text-slate-400 text-[14px] leading-relaxed">
            Join our developer Discord for real-time support.
          </p>
          <a
            href="/docs/community"
            class="block w-full text-center bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 rounded-lg py-2 text-slate-900 dark:text-slate-200 text-[12px] font-semibold shadow-sm hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors"
          >
            Join Community
          </a>
        </div>
        <div class="absolute -bottom-4 -right-4 w-20 h-20 opacity-10 dark:opacity-20 text-slate-900 dark:text-white">
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-full h-full">
            <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
          </svg>
        </div>
      </div>
    </div>
  </aside>
)}

<script>
  const tocLinks = document.querySelectorAll('[data-toc-link]');
  const headings = document.querySelectorAll('.docs-content h2, .docs-content h3');

  if (tocLinks.length > 0 && headings.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => {
              link.classList.remove('!text-pink-600', 'dark:!text-pink-400', '!font-medium');
            });
            const activeLink = document.querySelector(
              `[data-toc-link][href="#${entry.target.id}"]`
            );
            if (activeLink) {
              activeLink.classList.add('!text-pink-600', 'dark:!text-pink-400', '!font-medium');
            }
          }
        });
      },
      { rootMargin: '-80px 0px -80% 0px' }
    );

    headings.forEach((heading) => observer.observe(heading));
  }
</script>
