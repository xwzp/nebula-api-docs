---
import Logo from './Logo.astro';

interface Props {
  variant?: 'landing' | 'docs';
}

const { variant = 'docs' } = Astro.props;

const columns = [
  {
    title: 'Product',
    links: [
      { title: 'Features', href: '#' },
      { title: 'Models', href: '/docs/model-apis' },
      { title: 'Pricing', href: '/docs/pricing' },
    ],
  },
  {
    title: 'Company',
    links: [
      { title: 'About', href: '#' },
      { title: 'Blog', href: '#' },
      { title: 'Contact', href: '#' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { title: 'Privacy', href: '#' },
      { title: 'Terms', href: '#' },
    ],
  },
];
---

{variant === 'docs' ? (
  <!-- Docs footer: always dark -->
  <footer class="border-t border-dark-border bg-dark-bg">
    <div class="max-w-[1400px] mx-auto px-6 py-12">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
        <div class="col-span-2">
          <Logo variant="dark" />
          <p class="mt-3 text-sm max-w-xs text-dark-text-muted">
            Leading the charge in democratizing high-performance AI access for developers and enterprises worldwide.
          </p>
        </div>
        {columns.map((col) => (
          <div>
            <h4 class="font-display font-semibold text-sm mb-3 text-white">{col.title}</h4>
            <ul class="space-y-2">
              {col.links.map((link) => (
                <li>
                  <a href={link.href} class="text-sm transition-colors text-dark-text-muted hover:text-white">
                    {link.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="mt-10 pt-6 border-t border-dark-border flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-sm text-dark-text-muted">&copy; 2024 Nebula API. All rights reserved.</p>
        <div class="flex items-center gap-4">
          <a href="#" class="text-sm transition-colors text-dark-text-muted hover:text-white">Twitter</a>
          <a href="#" class="text-sm transition-colors text-dark-text-muted hover:text-white">GitHub</a>
        </div>
      </div>
    </div>
  </footer>
) : (
  <!-- Landing footer: responsive light/dark -->
  <footer class="border-t border-light-border dark:border-dark-border bg-light-surface dark:bg-dark-bg">
    <div class="max-w-[1400px] mx-auto px-6 py-12">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
        <div class="col-span-2">
          <Logo variant="responsive" />
          <p class="mt-3 text-sm max-w-xs text-light-text-muted dark:text-dark-text-muted">
            Leading the charge in democratizing high-performance AI access for developers and enterprises worldwide.
          </p>
        </div>
        {columns.map((col) => (
          <div>
            <h4 class="font-display font-semibold text-sm mb-3 text-light-text dark:text-white">{col.title}</h4>
            <ul class="space-y-2">
              {col.links.map((link) => (
                <li>
                  <a href={link.href} class="text-sm transition-colors text-light-text-muted dark:text-dark-text-muted hover:text-light-text dark:hover:text-white">
                    {link.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="mt-10 pt-6 border-t border-light-border dark:border-dark-border flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-sm text-light-text-muted dark:text-dark-text-muted">&copy; 2024 Nebula API. All rights reserved.</p>
        <div class="flex items-center gap-4">
          <a href="#" class="text-sm transition-colors text-light-text-muted dark:text-dark-text-muted hover:text-light-text dark:hover:text-white">Twitter</a>
          <a href="#" class="text-sm transition-colors text-light-text-muted dark:text-dark-text-muted hover:text-light-text dark:hover:text-white">GitHub</a>
        </div>
      </div>
    </div>
  </footer>
)}
