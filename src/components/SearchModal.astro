  };

  // Default icon
  const defaultIcon = 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2l5 5h-5V4zM6 20V4h5v7h7v9H6z';

  function getIconPath(iconName: string): string {
    return iconPaths[iconName] || defaultIcon;
  }

  let pagefind: any = null;
  let activeIndex = -1;
  let currentResults: any[] = [];
  let debounceTimer: ReturnType<typeof setTimeout>;

  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('search-results-list');
  const noResults = document.getElementById('no-results');
  const searchInitial = document.getElementById('search-initial');
  const searchLoading = document.getElementById('search-loading');

  // Get nav lookup from server
  const navLookup = (window as any).__navLookup || {};

  // Initialize Pagefind
  async function initPagefind() {
    if (pagefind) return pagefind;
    try {
      const importPagefind = new Function('return import("/pagefind/pagefind.js")');
      pagefind = await importPagefind();
      await pagefind.init();
      return pagefind;
    } catch (e) {
      console.warn('Pagefind not available:', e);
      return null;
    }
  }

  function getResultItems(): HTMLElement[] {
    return Array.from(document.querySelectorAll('.search-result-item'));
  }

  function updateActiveItem(newIndex: number) {
    const items = getResultItems();
    items.forEach(item => item.classList.remove('active'));

    if (items.length === 0) {
      activeIndex = -1;
      return;
    }

    if (newIndex < 0) newIndex = items.length - 1;
    if (newIndex >= items.length) newIndex = 0;

    activeIndex = newIndex;
    const activeItem = items[activeIndex];
    activeItem.classList.add('active');
    activeItem.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }

  function openSearch() {
    modal?.classList.remove('hidden');
    input?.focus();
    document.body.style.overflow = 'hidden';
    activeIndex = -1;
    initPagefind();
  }

  function closeSearch() {
    modal?.classList.add('hidden');
    if (input) input.value = '';
    document.body.style.overflow = '';
    if (resultsContainer) resultsContainer.innerHTML = '';
    noResults?.classList.add('hidden');
    searchInitial?.classList.remove('hidden');
    activeIndex = -1;
    currentResults = [];
  }

  async function performSearch(query: string) {
    const q = query.trim();

    if (!q) {
      if (resultsContainer) resultsContainer.innerHTML = '';
      noResults?.classList.add('hidden');
      searchInitial?.classList.remove('hidden');
      currentResults = [];
      activeIndex = -1;
      return;
    }

    searchInitial?.classList.add('hidden');
    searchLoading?.classList.remove('hidden');

    const pf = await initPagefind();
    if (!pf) {
      searchLoading?.classList.add('hidden');
      if (resultsContainer) {
        resultsContainer.innerHTML = `
          <div class="p-6 text-center text-slate-500 dark:text-slate-400">
            <p>搜索功能需要先运行构建命令</p>
            <code class="block mt-2 text-sm bg-slate-100 dark:bg-slate-700 px-3 py-1 rounded">npm run build</code>
          </div>
        `;
      }
      return;
    }

    try {
      const search = await pf.search(q);
      searchLoading?.classList.add('hidden');

      if (search.results.length === 0) {
        if (resultsContainer) resultsContainer.innerHTML = '';
        noResults?.classList.remove('hidden');
        currentResults = [];
        activeIndex = -1;
        return;
      }

      noResults?.classList.add('hidden');

      // Get results with sub_results for anchors
      const resultsData = await Promise.all(
        search.results.slice(0, 10).map(async (r: any) => {
          const data = await r.data();
          return data;
        })
      );

      // Flatten to include sub_results as separate items
      const results: any[] = [];
      for (const data of resultsData) {
        if (data.sub_results && data.sub_results.length > 0) {
          // Use sub_results for more precise matches with anchors
          for (const sub of data.sub_results) {
            results.push({
              url: sub.url || data.url,
              title: data.meta?.title,
              excerpt: sub.excerpt || data.excerpt,
              anchor: sub.anchor || null
            });
          }
        } else {
          results.push({
            url: data.url,
            title: data.meta?.title,
            excerpt: data.excerpt,
            anchor: null
          });
        }
        if (results.length >= 10) break;
      }
      currentResults = results.slice(0, 10);

      // Render results
      if (resultsContainer) {
        resultsContainer.innerHTML = currentResults.map((result: any, index: number) => {
          // Normalize URL for lookup (remove anchor and trailing slash)
          const baseUrl = result.url.split('#')[0].replace(/\/$/, '');
          const navItem = navLookup[baseUrl];

          // Get icon, title from nav or fallback
          const iconName = navItem?.icon || 'file';
          const iconPath = getIconPath(iconName);
          const iconColor = navItem?.color || 'text-purple-500';
          const section = navItem?.section || '';
          const label = navItem?.label || result.title || '无标题';
          const chevron = '<svg class="inline w-2.5 h-2.5 mx-1 text-slate-300 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>';
          const title = section ? `${section}${chevron}${label}` : label;

          // Keep mark tags for highlighting, remove other HTML
          const excerpt = result.excerpt
            ?.replace(/<(?!\/?mark)[^>]*>/g, '')
            ?.trim() || '';

          return `
          <a href="${result.url}" class="search-result-item" data-index="${index}">
            <span class="search-result-icon ${iconColor}">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="${iconPath}"/>
              </svg>
            </span>
            <div class="search-result-content">
              <div class="search-result-title">${title}</div>
              <div class="search-result-excerpt">${excerpt}</div>
            </div>
          </a>
        `}).join('');

        // Add click handlers
        getResultItems().forEach((item) => {
          item.addEventListener('click', (e) => {
            e.preventDefault();
            const href = item.getAttribute('href');
            if (href) {
              document.body.style.overflow = '';
              window.location.href = href;
            }
          });
        });

        if (results.length > 0) {
          updateActiveItem(0);
        }
      }
    } catch (e) {
      console.error('Search error:', e);
      searchLoading?.classList.add('hidden');
    }
  }

  function navigateToActive() {
    const items = getResultItems();
    if (activeIndex >= 0 && activeIndex < items.length) {
      const href = items[activeIndex].getAttribute('href');
      if (href) {
        document.body.style.overflow = '';
        window.location.href = href;
      }
    }
  }

  // Keyboard events
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (modal?.classList.contains('hidden')) {
        openSearch();
      } else {
        closeSearch();
      }
      return;
    }

    if (modal?.classList.contains('hidden')) return;

    if (e.key === 'Escape') {
      e.preventDefault();
      closeSearch();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      updateActiveItem(activeIndex + 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      updateActiveItem(activeIndex - 1);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      navigateToActive();
    }
  });

  document.querySelectorAll('[data-search-trigger]').forEach(btn => {
    btn.addEventListener('click', openSearch);
  });

  backdrop?.addEventListener('click', closeSearch);

  input?.addEventListener('input', (e) => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      performSearch((e.target as HTMLInputElement).value);
    }, 200);
  });
</script>
