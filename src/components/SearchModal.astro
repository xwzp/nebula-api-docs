---
// Pagefind search modal - indexes content at build time
---

<!-- Search Modal -->
<div id="search-modal" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Modal -->
  <div class="relative flex items-start justify-center pt-[15vh] px-4">
    <div class="w-full max-w-xl bg-white dark:bg-slate-800 rounded-2xl shadow-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
      <!-- Search Input -->
      <div class="flex items-center gap-3 px-4 py-3 border-b border-slate-200 dark:border-slate-700">
        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="搜索文档..."
          class="flex-1 bg-transparent text-slate-900 dark:text-white placeholder-slate-400 outline-none text-base"
          autocomplete="off"
        />
        <div id="search-loading" class="hidden">
          <svg class="w-5 h-5 text-slate-400 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
        <kbd class="px-2 py-1 bg-slate-100 dark:bg-slate-700 rounded text-xs text-slate-500 dark:text-slate-400 font-mono">ESC</kbd>
      </div>

      <!-- Search Results -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
        <!-- Initial state -->
        <div id="search-initial" class="p-6 text-center text-slate-500 dark:text-slate-400">
          <p>输入关键词搜索文档内容</p>
        </div>

        <!-- Results will be injected here -->
        <div id="search-results-list"></div>

        <!-- No Results -->
        <div id="no-results" class="hidden p-8 text-center">
          <div class="text-slate-400 dark:text-slate-500 mb-2">
            <svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <p class="text-slate-500 dark:text-slate-400">没有找到相关结果</p>
        </div>
      </div>

      <!-- Footer hint -->
      <div class="px-4 py-2 border-t border-slate-200 dark:border-slate-700 flex items-center gap-4 text-xs text-slate-400">
        <span class="flex items-center gap-1">
          <kbd class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded font-mono">↑</kbd>
          <kbd class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded font-mono">↓</kbd>
          <span class="ml-1">导航</span>
        </span>
        <span class="flex items-center gap-1">
          <kbd class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded font-mono">Enter</kbd>
          <span class="ml-1">打开</span>
        </span>
        <span class="flex items-center gap-1">
          <kbd class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded font-mono">ESC</kbd>
          <span class="ml-1">关闭</span>
        </span>
      </div>
    </div>
  </div>
</div>

<style>
  .search-result-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.5rem;
    transition: background-color 0.15s;
    cursor: pointer;
  }
  .search-result-item:hover,
  .search-result-item.active {
    background-color: rgb(241 245 249); /* slate-100 */
  }
  :global(.dark) .search-result-item:hover,
  :global(.dark) .search-result-item.active {
    background-color: rgb(51 65 85 / 0.5); /* slate-700/50 */
  }
  .search-result-item mark {
    background-color: rgb(233 213 255); /* purple-200 */
    color: rgb(88 28 135); /* purple-900 */
    border-radius: 0.125rem;
    padding: 0 0.125rem;
  }
  :global(.dark) .search-result-item mark {
    background-color: rgb(168 85 247 / 0.3); /* purple-500/30 */
    color: rgb(233 213 255); /* purple-200 */
  }
</style>

<script>
  let pagefind: any = null;
  let activeIndex = -1;
  let currentResults: any[] = [];
  let debounceTimer: ReturnType<typeof setTimeout>;

  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('search-results-list');
  const noResults = document.getElementById('no-results');
  const searchInitial = document.getElementById('search-initial');
  const searchLoading = document.getElementById('search-loading');

  // Initialize Pagefind (loaded dynamically at runtime, bypassing Vite bundler)
  async function initPagefind() {
    if (pagefind) return pagefind;
    try {
      // Use Function constructor to bypass Vite's static analysis
      const importPagefind = new Function('return import("/pagefind/pagefind.js")');
      pagefind = await importPagefind();
      await pagefind.init();
      return pagefind;
    } catch (e) {
      console.warn('Pagefind not available (run npm run build first):', e);
      return null;
    }
  }

  function getResultItems(): HTMLElement[] {
    return Array.from(document.querySelectorAll('.search-result-item'));
  }

  function updateActiveItem(newIndex: number) {
    const items = getResultItems();
    items.forEach(item => item.classList.remove('active'));

    if (items.length === 0) {
      activeIndex = -1;
      return;
    }

    if (newIndex < 0) newIndex = items.length - 1;
    if (newIndex >= items.length) newIndex = 0;

    activeIndex = newIndex;
    const activeItem = items[activeIndex];
    activeItem.classList.add('active');
    activeItem.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }

  function openSearch() {
    modal?.classList.remove('hidden');
    input?.focus();
    document.body.style.overflow = 'hidden';
    activeIndex = -1;
    // Preload pagefind
    initPagefind();
  }

  function closeSearch() {
    modal?.classList.add('hidden');
    if (input) input.value = '';
    document.body.style.overflow = '';
    // Reset
    if (resultsContainer) resultsContainer.innerHTML = '';
    noResults?.classList.add('hidden');
    searchInitial?.classList.remove('hidden');
    activeIndex = -1;
    currentResults = [];
  }

  async function performSearch(query: string) {
    const q = query.trim();

    if (!q) {
      if (resultsContainer) resultsContainer.innerHTML = '';
      noResults?.classList.add('hidden');
      searchInitial?.classList.remove('hidden');
      currentResults = [];
      activeIndex = -1;
      return;
    }

    searchInitial?.classList.add('hidden');
    searchLoading?.classList.remove('hidden');

    const pf = await initPagefind();
    if (!pf) {
      searchLoading?.classList.add('hidden');
      if (resultsContainer) {
        resultsContainer.innerHTML = `
          <div class="p-6 text-center text-slate-500 dark:text-slate-400">
            <p>搜索功能需要先运行构建命令</p>
            <code class="block mt-2 text-sm bg-slate-100 dark:bg-slate-700 px-3 py-1 rounded">npm run build</code>
          </div>
        `;
      }
      return;
    }

    try {
      const search = await pf.search(q);
      searchLoading?.classList.add('hidden');

      if (search.results.length === 0) {
        if (resultsContainer) resultsContainer.innerHTML = '';
        noResults?.classList.remove('hidden');
        currentResults = [];
        activeIndex = -1;
        return;
      }

      noResults?.classList.add('hidden');

      // Load result data (limit to 10 for performance)
      const results = await Promise.all(
        search.results.slice(0, 10).map((r: any) => r.data())
      );
      currentResults = results;

      // Render results
      if (resultsContainer) {
        resultsContainer.innerHTML = results.map((result: any, index: number) => `
          <a href="${result.url}" class="search-result-item" data-index="${index}">
            <div class="text-sm font-medium text-slate-900 dark:text-white truncate">
              ${result.meta?.title || '无标题'}
            </div>
            <div class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2">
              ${result.excerpt || ''}
            </div>
          </a>
        `).join('');

        // Add click handlers
        getResultItems().forEach((item, index) => {
          item.addEventListener('click', (e) => {
            e.preventDefault();
            const href = item.getAttribute('href');
            if (href) {
              document.body.style.overflow = '';
              window.location.href = href;
            }
          });
        });

        // Highlight first result
        if (results.length > 0) {
          updateActiveItem(0);
        }
      }
    } catch (e) {
      console.error('Search error:', e);
      searchLoading?.classList.add('hidden');
    }
  }

  function navigateToActive() {
    const items = getResultItems();
    if (activeIndex >= 0 && activeIndex < items.length) {
      const href = items[activeIndex].getAttribute('href');
      if (href) {
        document.body.style.overflow = '';
        window.location.href = href;
      }
    }
  }

  // Keyboard events
  document.addEventListener('keydown', (e) => {
    // Open search with Cmd/Ctrl + K
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (modal?.classList.contains('hidden')) {
        openSearch();
      } else {
        closeSearch();
      }
      return;
    }

    // Only handle other keys when modal is open
    if (modal?.classList.contains('hidden')) return;

    if (e.key === 'Escape') {
      e.preventDefault();
      closeSearch();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      updateActiveItem(activeIndex + 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      updateActiveItem(activeIndex - 1);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      navigateToActive();
    }
  });

  // Click on search buttons
  document.querySelectorAll('[data-search-trigger]').forEach(btn => {
    btn.addEventListener('click', openSearch);
  });

  // Close on backdrop click
  backdrop?.addEventListener('click', closeSearch);

  // Debounced search on input
  input?.addEventListener('input', (e) => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      performSearch((e.target as HTMLInputElement).value);
    }, 200);
  });
</script>
