---
import { sidebarSections } from '../config/navigation';

// Build a lookup map for navigation items
const navLookup: Record<string, { section: string; label: string; icon: string; color: string }> = {};
sidebarSections.forEach(section => {
  section.items.forEach(item => {
    // Normalize href (remove hash)
    const baseHref = item.href.split('#')[0];
    navLookup[baseHref] = {
      section: section.title,
      label: item.label,
      icon: item.icon,
      color: item.color
    };
  });
});
---

<!-- Search Modal -->
<div id="search-modal" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Modal -->
  <div class="relative flex items-start justify-center pt-[15vh] px-4">
    <div class="w-full max-w-xl bg-white dark:bg-slate-800 rounded-2xl shadow-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
      <!-- Search Input -->
      <div class="flex items-center gap-3 px-4 py-3 border-b border-slate-200 dark:border-slate-700">
        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="搜索文档..."
          class="flex-1 bg-transparent text-slate-900 dark:text-white placeholder-slate-400 outline-none text-base"
          autocomplete="off"
        />
        <div id="search-loading" class="hidden">
          <svg class="w-5 h-5 text-slate-400 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
        <kbd class="px-2 py-1 bg-slate-100 dark:bg-slate-700 rounded text-xs text-slate-500 dark:text-slate-400 font-mono">ESC</kbd>
      </div>

      <!-- Search Results -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
        <!-- Initial state -->
        <div id="search-initial" class="p-6 text-center text-slate-500 dark:text-slate-400">
          <p>输入关键词搜索文档内容</p>
        </div>

        <!-- Results will be injected here -->
        <div id="search-results-list"></div>

        <!-- No Results -->
        <div id="no-results" class="hidden p-8 text-center">
          <div class="text-slate-400 dark:text-slate-500 mb-2">
            <svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <p class="text-slate-500 dark:text-slate-400">没有找到相关结果</p>
        </div>
      </div>

      <!-- Footer hint -->
      <div class="px-4 py-2 border-t border-slate-200 dark:border-slate-700 flex items-center gap-4 text-xs text-slate-400">
        <span class="flex items-center gap-1">
          <kbd class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded font-mono">↑</kbd>
          <kbd class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded font-mono">↓</kbd>
          <span class="ml-1">导航</span>
        </span>
        <span class="flex items-center gap-1">
          <kbd class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded font-mono">Enter</kbd>
          <span class="ml-1">打开</span>
        </span>
        <span class="flex items-center gap-1">
          <kbd class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded font-mono">ESC</kbd>
          <span class="ml-1">关闭</span>
        </span>
      </div>
    </div>
  </div>
</div>

<!-- Pass navigation data to client -->
<script is:inline define:vars={{ navLookup }}>
  window.__navLookup = navLookup;
</script>

<style is:global>
  .search-result-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.5rem;
    transition: background-color 0.15s;
    cursor: pointer;
    text-decoration: none;
  }
  .search-result-item:hover,
  .search-result-item.active {
    background-color: rgb(241 245 249);
  }
  .dark .search-result-item:hover,
  .dark .search-result-item.active {
    background-color: rgb(51 65 85 / 0.5);
  }
  .search-result-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    flex-shrink: 0;
    background-color: rgb(241 245 249);
  }
  .dark .search-result-icon {
    background-color: rgb(51 65 85 / 0.5);
  }
  .search-result-content {
    min-width: 0;
    flex: 1;
  }
  .search-result-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: rgb(15 23 42);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .dark .search-result-title {
    color: rgb(255 255 255);
  }
  .search-result-excerpt {
    font-size: 0.75rem;
    color: rgb(100 116 139);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .dark .search-result-excerpt {
    color: rgb(148 163 184);
  }
  .search-result-excerpt mark {
    background-color: rgb(254 240 138);
    color: inherit;
    padding: 0 2px;
    border-radius: 2px;
  }
  .dark .search-result-excerpt mark {
    background-color: rgb(161 98 7);
  }
</style>

