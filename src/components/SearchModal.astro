---
import { sidebarSections } from '../config/navigation';

// Flatten all navigation items for search with breadcrumb
const searchItems = sidebarSections.flatMap(section =>
  section.items.map(item => ({
    ...item,
    section: section.title,
    breadcrumb: `${section.title} / ${item.label}`
  }))
);
---

<!-- Search Modal -->
<div id="search-modal" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Modal -->
  <div class="relative flex items-start justify-center pt-[15vh] px-4">
    <div class="w-full max-w-xl bg-white dark:bg-slate-800 rounded-2xl shadow-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
      <!-- Search Input -->
      <div class="flex items-center gap-3 px-4 py-3 border-b border-slate-200 dark:border-slate-700">
        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="搜索文档..."
          class="flex-1 bg-transparent text-slate-900 dark:text-white placeholder-slate-400 outline-none text-base"
          autocomplete="off"
        />
        <kbd class="px-2 py-1 bg-slate-100 dark:bg-slate-700 rounded text-xs text-slate-500 dark:text-slate-400 font-mono">ESC</kbd>
      </div>

      <!-- Search Results -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
        {searchItems.map((item, index) => (
          <a
            href={item.href}
            class="search-item flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors"
            data-index={index}
            data-label={item.label.toLowerCase()}
            data-section={item.section.toLowerCase()}
            data-breadcrumb={item.breadcrumb.toLowerCase()}
          >
            <span class={`w-8 h-8 rounded-lg flex items-center justify-center shrink-0 ${item.color} bg-slate-100 dark:bg-slate-700/50`}>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
              </svg>
            </span>
            <div class="min-w-0">
              <div class="text-sm font-medium text-slate-900 dark:text-white truncate">{item.label}</div>
              <div class="text-xs text-slate-500 dark:text-slate-400 truncate">{item.section} / {item.label}</div>
            </div>
          </a>
        ))}

        <!-- No Results -->
        <div id="no-results" class="hidden p-8 text-center">
          <div class="text-slate-400 dark:text-slate-500 mb-2">
            <svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <p class="text-slate-500 dark:text-slate-400">没有找到相关结果</p>
        </div>
      </div>

      <!-- Footer hint -->
      <div class="px-4 py-2 border-t border-slate-200 dark:border-slate-700 flex items-center gap-4 text-xs text-slate-400">
        <span class="flex items-center gap-1">
          <kbd class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded font-mono">↑</kbd>
          <kbd class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded font-mono">↓</kbd>
          <span class="ml-1">导航</span>
        </span>
        <span class="flex items-center gap-1">
          <kbd class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded font-mono">Enter</kbd>
          <span class="ml-1">打开</span>
        </span>
        <span class="flex items-center gap-1">
          <kbd class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded font-mono">ESC</kbd>
          <span class="ml-1">关闭</span>
        </span>
      </div>
    </div>
  </div>
</div>

<style>
  .search-item:hover,
  .search-item.active {
    background-color: rgb(241 245 249); /* slate-100 */
  }
  :global(.dark) .search-item:hover,
  :global(.dark) .search-item.active {
    background-color: rgb(51 65 85 / 0.5); /* slate-700/50 */
  }
</style>

<script>
  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('search-results');
  const noResults = document.getElementById('no-results');
  let searchItems = Array.from(document.querySelectorAll('.search-item')) as HTMLElement[];
  let activeIndex = -1;

  function getVisibleItems(): HTMLElement[] {
    return searchItems.filter(item => !item.classList.contains('hidden'));
  }

  function updateActiveItem(newIndex: number) {
    const visibleItems = getVisibleItems();

    // Remove active class from all items
    searchItems.forEach(item => item.classList.remove('active'));

    if (visibleItems.length === 0) {
      activeIndex = -1;
      return;
    }

    // Clamp index
    if (newIndex < 0) newIndex = visibleItems.length - 1;
    if (newIndex >= visibleItems.length) newIndex = 0;

    activeIndex = newIndex;
    const activeItem = visibleItems[activeIndex];
    activeItem.classList.add('active');

    // Scroll into view
    activeItem.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }

  function openSearch() {
    modal?.classList.remove('hidden');
    input?.focus();
    document.body.style.overflow = 'hidden';
    activeIndex = -1;
    // Highlight first item
    const visibleItems = getVisibleItems();
    if (visibleItems.length > 0) {
      updateActiveItem(0);
    }
  }

  function closeSearch() {
    modal?.classList.add('hidden');
    if (input) input.value = '';
    document.body.style.overflow = '';
    // Reset search results
    searchItems.forEach(item => item.classList.remove('hidden', 'active'));
    noResults?.classList.add('hidden');
    activeIndex = -1;
  }

  function filterResults(query: string) {
    const q = query.toLowerCase().trim();
    let hasResults = false;

    searchItems.forEach(item => {
      const label = item.getAttribute('data-label') || '';
      const section = item.getAttribute('data-section') || '';
      const breadcrumb = item.getAttribute('data-breadcrumb') || '';
      const matches = q === '' || label.includes(q) || section.includes(q) || breadcrumb.includes(q);

      if (matches) {
        item.classList.remove('hidden');
        hasResults = true;
      } else {
        item.classList.add('hidden');
      }
    });

    if (hasResults || q === '') {
      noResults?.classList.add('hidden');
    } else {
      noResults?.classList.remove('hidden');
    }

    // Reset active index and highlight first visible item
    activeIndex = -1;
    const visibleItems = getVisibleItems();
    if (visibleItems.length > 0) {
      updateActiveItem(0);
    }
  }

  function navigateToActive() {
    const visibleItems = getVisibleItems();
    if (activeIndex >= 0 && activeIndex < visibleItems.length) {
      const activeItem = visibleItems[activeIndex] as HTMLAnchorElement;
      const href = activeItem.getAttribute('href');
      if (href && href !== '#') {
        document.body.style.overflow = '';
        window.location.href = href;
      }
    }
  }

  function navigateToItem(item: HTMLElement) {
    const href = item.getAttribute('href');
    if (href && href !== '#') {
      document.body.style.overflow = '';
      window.location.href = href;
    }
  }

  // Keyboard events
  document.addEventListener('keydown', (e) => {
    // Open search with Cmd/Ctrl + K
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (modal?.classList.contains('hidden')) {
        openSearch();
      } else {
        closeSearch();
      }
      return;
    }

    // Only handle other keys when modal is open
    if (modal?.classList.contains('hidden')) return;

    if (e.key === 'Escape') {
      e.preventDefault();
      closeSearch();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      updateActiveItem(activeIndex + 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      updateActiveItem(activeIndex - 1);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      navigateToActive();
    }
  });

  // Click on search buttons
  document.querySelectorAll('[data-search-trigger]').forEach(btn => {
    btn.addEventListener('click', openSearch);
  });

  // Close on backdrop click
  backdrop?.addEventListener('click', closeSearch);

  // Filter on input
  input?.addEventListener('input', (e) => {
    filterResults((e.target as HTMLInputElement).value);
  });

  // Click on search item
  searchItems.forEach(item => {
    item.addEventListener('click', (e) => {
      e.preventDefault();
      navigateToItem(item);
    });
  });
</script>
